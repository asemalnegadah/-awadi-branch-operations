# Public application metadata
NEXT_PUBLIC_APP_NAME="نظام تشغيل ورقابة فرع العوادي – عدن"
NEXT_PUBLIC_APP_ENV="development"

# Server-only database connection. Never commit a real value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Authentication secrets. Generate a random value of at least 32 characters
# outside GitHub and store it in the deployment secret manager.
AUTH_SECRET="replace-with-a-strong-random-secret-of-at-least-32-characters"
SESSION_TTL_HOURS="8"
SESSION_IDLE_TIMEOUT_MINUTES="60"
LOGIN_EMAIL_MAX_PER_15_MINUTES="10"
LOGIN_IP_MAX_PER_15_MINUTES="30"

# Email activation and password recovery.
APP_BASE_URL="http://localhost:3000"
# Comma-separated origins only; leave empty when APP_BASE_URL is the sole origin.
TRUSTED_ORIGINS=""
RESEND_API_KEY="replace-with-a-server-only-api-key"
EMAIL_FROM="مجموعة العوادي التجارية <security@example.com>"
PASSWORD_RESET_TTL_MINUTES="30"
PASSWORD_RESET_EMAIL_MAX_PER_HOUR="3"
PASSWORD_RESET_IP_MAX_PER_HOUR="10"
ALLOW_INITIAL_MANAGER_EMAIL_BOOTSTRAP="false"
INITIAL_MANAGER_EMAIL="manager@example.com"
INITIAL_MANAGER_NAME="اسم مدير الفرع"

# Legacy one-time manager bootstrap values. Prefer email activation for production.
# Supply these only to the bootstrap command and remove the password immediately.
MANAGER_EMAIL="manager@example.com"
MANAGER_NAME="اسم مدير الفرع"
MANAGER_PASSWORD="replace-with-a-strong-password"
ALLOW_MANAGER_PASSWORD_RESET="false"

# Optional storage adapter settings. Real values belong in the deployment secret store.
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
