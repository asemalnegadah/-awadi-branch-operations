{
  "name": "awadi-branch-operations",
  "version": "0.1.0",
  "private": true,
  "description": "نظام تشغيل ورقابة فرع العوادي – عدن",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:migrations:upgrade": "bash scripts/test-payment-promises-upgrade.sh",
    "verify:migrations": "node scripts/verify-migrations.mjs",
    "verify:cloudflare": "node scripts/verify-cloudflare-config.mjs",
    "bootstrap:manager": "node scripts/bootstrap-manager.mjs",
    "check": "npm run verify:migrations && npm run verify:cloudflare && npm run lint && npm run typecheck && npm run test && npm run build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && opennextjs-cloudflare preview",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:dry-run:built": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "cf:check": "npm run verify:cloudflare && npm run cf:build && npm run cf:dry-run:built"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "next": "16.2.10",
    "pdfjs-dist": "6.1.200",
    "postgres": "3.4.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.39.0",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
