{
  "name": "awadi-branch-operations",
  "version": "0.1.0",
  "private": true,
  "description": "نظام تشغيل ورقابة فرع العوادي – عدن",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "verify:migrations": "node scripts/verify-migrations.mjs",
    "check": "npm run verify:migrations && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "next": "16.2.10",
    "pdfjs-dist": "5.4.449",
    "postgres": "3.4.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.39.0",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
